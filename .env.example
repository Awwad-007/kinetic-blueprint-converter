# ── PostgreSQL connection (KINETIC main database)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=kinetic
PG_USER=postgres
PG_PASSWORD=your_password_here

# ── Path to the KINETIC main project (so JSON is written into it)
KINETIC_PROJECT_ROOT=../

# ── Where to write the generated JSON asset inside the main project
KINETIC_ASSET_PATH=client/assets/floorplans

# ── Server config for this converter tool
CONVERTER_PORT=4000

# ── Upload limits (bytes)
MAX_FILE_SIZE_MB=150


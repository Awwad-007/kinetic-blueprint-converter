CONVERTER_PORT=4000
MAX_FILE_SIZE_MB=150

# Target the root directory of your main KINETIC repository
KINETIC_PROJECT_ROOT=../KINETIC
KINETIC_ASSET_PATH=client/assets/floorplans

# Your master PostgreSQL credentials
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=kinetic
PG_USER=postgres
PG_PASSWORD=your_secure_password